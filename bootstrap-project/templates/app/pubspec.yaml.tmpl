name: {{PROJECT_SNAKE}}
description: "{{PROJECT_DESCRIPTION}} — mobile app."
publish_to: 'none'
version: 0.1.0+1

environment:
  sdk: '>=3.5.0 <4.0.0'
  flutter: '>={{FLUTTER_VERSION}}'

dependencies:
  cupertino_icons: ^1.0.8
  decimal: ^3.0.2
  dio: ^5.7.0
  envied: ^1.0.0
  flutter:
    sdk: flutter
  flutter_localizations:
    sdk: flutter
  flutter_riverpod: ^2.5.1
  flutter_secure_storage: ^9.2.2
  freezed_annotation: ^2.4.4
  go_router: ^14.6.1
  intl: ^0.20.2
  json_annotation: ^4.9.0
  riverpod_annotation: ^2.3.5

dev_dependencies:
  build_runner: ^2.4.13
  custom_lint: ^0.7.0
  envied_generator: ^1.0.0
  flutter_test:
    sdk: flutter
  freezed: ^2.5.7
  json_serializable: ^6.8.0
  riverpod_generator: ^2.4.3
  very_good_analysis: ^6.0.0

# Fallback: custom_lint 0.7.x transitively pulls analyzer_plugin 0.12.0 which
# fails to compile against analyzer 7.x (it calls removed Element2 APIs).
# Pin analyzer_plugin to the latest 0.13.x that still targets analyzer ^7.5.1.
dependency_overrides:
  analyzer_plugin: ^0.13.4

flutter:
  uses-material-design: true
  generate: true
