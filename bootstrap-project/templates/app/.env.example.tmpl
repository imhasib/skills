# =============================================================================
# {{PROJECT}}-app — environment for local dev.
#
# Copy this to .env:
#   cp .env.example .env
# Then regenerate the envied bindings:
#   dart run build_runner build --delete-conflicting-outputs
#
# IMPORTANT: .env is read at BUILD time (compile-time const) — every change
# needs a rebuild + a hot restart, not just hot reload.
# =============================================================================

# Backend API base — points at the local dev stack via nginx by default.
# nginx fronts both `user-service` (/api/auth, /api/users, /api/assets) and
# `{{PROJECT}}-core` (/api/*) on the same host, so one base URL covers both.
#
# Android emulator: localhost on the host = 10.0.2.2 inside the emulator.
# iOS simulator: localhost works directly (use http://localhost/api).
# Physical device: use the LAN IP of your dev machine (e.g. http://192.168.1.42/api).
# Bypassing nginx (hit a service port directly): point at e.g. http://10.0.2.2:3030
#   — but then user-service routes will 404, so only do this if you're calling
#   `{{PROJECT}}-core` exclusively.
API_BASE_URL=http://10.0.2.2/api
ENVIRONMENT=dev
