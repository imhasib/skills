import 'package:envied/envied.dart';

part 'env.g.dart';

/// Compile-time env config. Values are baked into the binary at build time
/// — every change requires a rebuild (a hot restart is NOT enough).
///
/// Regenerate after editing .env:
///   dart run build_runner build --delete-conflicting-outputs
@Envied(path: '.env', requireEnvFile: false)
abstract class Env {
  @EnviedField(varName: 'API_BASE_URL')
  static const String apiBaseUrl = _Env.apiBaseUrl;

  @EnviedField(varName: 'ENVIRONMENT', defaultValue: 'dev')
  static const String environment = _Env.environment;
}
