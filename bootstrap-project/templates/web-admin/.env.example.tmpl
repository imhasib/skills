# Public, build-time values (safe to ship to the browser).
NEXT_PUBLIC_ENVIRONMENT=dev

# Server-only secrets. Copy to `.env.local` (gitignored) and fill in real values.

# Google OAuth client ID. Provision in Google Cloud Console.
# Public by design — the browser uses it to talk to Google Identity Services
# directly. The OAuth client *secret* never lives here: only user-service
# holds it, because only user-service validates Google id_tokens.
AUTH_GOOGLE_ID=<FILL_IN_GOOGLE_OAUTH_CLIENT_ID>

# Server-side base URL for the backend, fronted by nginx.
# - nginx routes /api/{auth,users,email,assets}/* → user-service and the
#   /api/* catch-all → {{PROJECT}}-core (see {{PROJECT}}-deployment/shared/nginx/locations.conf),
#   so the admin only needs one URL regardless of which backend serves a path.
# - user-service mounts its router at `/api/v1`; the nginx location blocks
#   for user-service prefixes rewrite to `/api/v1/...` upstream, so callers
#   here stay base-relative (e.g. `/auth/google`, `/users/me`).
# - {{PROJECT}}-core mounts at `/api` (no URL versioning; it uses the
#   `API-Version` header instead — see docs/API_CONTRACT.md).
# - In dev, nginx is exposed on the host port mapped by
#   {{PROJECT}}-deployment/dev/docker-compose.yml; in staging/prod it sits
#   behind the public gateway. The env shape stays the same across envs.
{{PROJECT_UPPER}}_API_BASE_URL=http://localhost/api
