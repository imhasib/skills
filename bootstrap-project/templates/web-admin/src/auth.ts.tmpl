import NextAuth from 'next-auth';
import Google from 'next-auth/providers/google';

/**
 * Auth.js v5 configuration for the {{PROJECT}} admin console.
 *
 * Flow:
 * 1. User clicks "Sign in with Google" → Google issues an `id_token`.
 * 2. We POST `{ idToken }` to user-service via nginx `POST /api/auth/google`
 *    (nginx rewrites to user-service's `/api/v1/auth/google` mount), which
 *    validates the Google token and returns `{ user, tokens }` with the
 *    backend-issued access token under `tokens.accessToken`.
 * 3. The backend JWT (`backendToken`) is persisted on the NextAuth JWT and
 *    exposed via `session.backendToken`, so server components can forward it
 *    as a Bearer token to backend requests.
 *
 * The Next.js admin never verifies the backend JWT signature locally — that
 * responsibility lives in {{PROJECT}}-core (validator) and user-service (issuer).
 *
 * AUTH_GOOGLE_ID, AUTH_GOOGLE_SECRET, and AUTH_SECRET are injected by Auth.js
 * from the matching env vars.
 */

interface BackendUser {
  id: string;
  name: string;
  email: string;
  avatar_url?: string;
}

interface UserServiceGoogleResponse {
  token: string;
  user: BackendUser;
}

/**
 * Wire format actually returned by user-service `POST /api/v1/auth/google`
 * (see `googleMobileAuth` controller). The body is `{ user, tokens }` with
 * the access token under `tokens.accessToken` and a sibling refresh token.
 * We only consume the access token here — refresh is not yet wired.
 */
interface UserServiceGoogleRawResponse {
  user: BackendUser;
  tokens: {
    accessToken: string;
    refreshToken?: string;
  };
}

// Single backend base URL — nginx routes /api/auth/* → user-service (rewriting
// to its /api/v1 mount) and the /api/* catch-all → {{PROJECT}}-core. Callers
// stay base-relative (`/auth/google`, `/users/me`, ...).
const API_BASE_URL = process.env.{{PROJECT_UPPER}}_API_BASE_URL ?? 'http://localhost/api';

async function exchangeGoogleIdToken(idToken: string): Promise<UserServiceGoogleResponse> {
  const res = await fetch(`${API_BASE_URL}/auth/google`, {
    method: 'POST',
    headers: {
      'Content-Type': 'application/json',
      Accept: 'application/json',
      'API-Version': 'v1',
    },
    // user-service expects `idToken` (camelCase) per its controller contract.
    body: JSON.stringify({ idToken }),
    cache: 'no-store',
  });

  if (!res.ok) {
    let message = `user-service rejected Google sign-in (HTTP ${String(res.status)})`;
    try {
      const body = (await res.json()) as { code?: unknown; message?: unknown };
      if (typeof body.message === 'string') {
        message = body.message;
      }
    } catch {
      // fall through to the generic message
    }
    throw new Error(message);
  }

  const raw = (await res.json()) as Partial<UserServiceGoogleRawResponse>;
  const accessToken = raw.tokens?.accessToken;
  const user = raw.user;
  if (!accessToken || !user) {
    throw new Error('user-service returned an unexpected Google sign-in payload');
  }
  return { token: accessToken, user };
}

export const { handlers, auth, signIn, signOut } = NextAuth({
  trustHost: true,
  providers: [
    Google({
      clientId: process.env.AUTH_GOOGLE_ID,
      clientSecret: process.env.AUTH_GOOGLE_SECRET,
    }),
  ],
  pages: {
    signIn: '/login',
    error: '/login',
  },
  session: {
    strategy: 'jwt',
  },
  callbacks: {
    async signIn({ account }) {
      if (account?.provider !== 'google') {
        return false;
      }
      const idToken = account.id_token;
      if (typeof idToken !== 'string' || idToken.length === 0) {
        return '/login?error=GoogleNoIdToken';
      }

      try {
        const exchanged = await exchangeGoogleIdToken(idToken);
        // Stash the result on the account so it survives into the jwt callback.
        // Auth.js does not pass arbitrary fields through directly.
        (account as unknown as { backend?: UserServiceGoogleResponse }).backend = exchanged;
        return true;
      } catch (err) {
        const message = err instanceof Error ? err.message : 'GoogleExchangeFailed';
        // Returning a string redirects to that URL; encode the message so the
        // login page can render a friendly error banner.
        return `/login?error=${encodeURIComponent(message)}`;
      }
    },
    jwt({ token, account }) {
      const stashed = (account as unknown as { backend?: UserServiceGoogleResponse } | null)
        ?.backend;
      if (stashed) {
        token.backendToken = stashed.token;
        token.backendUser = stashed.user;
      }
      return token;
    },
    session({ session, token }) {
      if (typeof token.backendToken === 'string') {
        session.backendToken = token.backendToken;
      }
      if (token.backendUser) {
        session.backendUser = token.backendUser;
      }
      return session;
    },
  },
});
