import NextAuth, { type User as NextAuthUser } from 'next-auth';
import Credentials from 'next-auth/providers/credentials';

/**
 * Auth.js v5 configuration for the {{PROJECT}} web app.
 *
 * Flow:
 * 1. The browser obtains a Google `id_token` directly via Google Identity
 *    Services (`<GoogleSignInButton>`). No OAuth client secret is held by
 *    this app — only the public client ID (`AUTH_GOOGLE_ID`).
 * 2. The client POSTs the id_token through NextAuth's Credentials provider,
 *    whose `authorize()` forwards it to user-service via
 *    `POST /api/auth/google` (nginx rewrites to user-service's
 *    `/api/v1/auth/google` mount), which validates the Google token and
 *    returns `{ user, tokens }` with the backend-issued access token under
 *    `tokens.accessToken`.
 * 3. The backend JWT (`backendToken`) is persisted on the NextAuth JWT and
 *    exposed via `session.backendToken`, so server components can forward it
 *    as a Bearer token to backend requests.
 *
 * The Next.js app never verifies the backend JWT signature locally — that
 * responsibility lives in {{PROJECT}}-core (validator) and user-service (issuer).
 *
 * AUTH_SECRET is injected by Auth.js from the matching env var.
 */

interface BackendUser {
  id: string;
  name: string;
  email: string;
  avatar_url?: string;
}

/**
 * Wire format returned by user-service `POST /api/v1/auth/google` (see
 * `googleMobileAuth` controller). The body is `{ user, tokens }` with the
 * access token under `tokens.accessToken` and a sibling refresh token.
 * We only consume the access token here — refresh is not yet wired.
 */
interface UserServiceGoogleRawResponse {
  user: BackendUser;
  tokens: {
    accessToken: string;
    refreshToken?: string;
  };
}

// Single backend base URL — nginx routes /api/auth/* → user-service (rewriting
// to its /api/v1 mount) and the /api/* catch-all → {{PROJECT}}-core. Callers
// stay base-relative (`/auth/google`, `/users/me`, ...).
const API_BASE_URL = process.env.{{PROJECT_UPPER}}_API_BASE_URL ?? 'http://localhost/api';

async function exchangeGoogleIdToken(
  idToken: string,
): Promise<{ accessToken: string; user: BackendUser }> {
  const res = await fetch(`${API_BASE_URL}/auth/google`, {
    method: 'POST',
    headers: {
      'Content-Type': 'application/json',
      Accept: 'application/json',
      'API-Version': 'v1',
    },
    // user-service expects `idToken` (camelCase) per its controller contract.
    body: JSON.stringify({ idToken }),
    cache: 'no-store',
  });

  if (!res.ok) {
    let message = `user-service rejected Google sign-in (HTTP ${String(res.status)})`;
    try {
      const body = (await res.json()) as { message?: unknown };
      if (typeof body.message === 'string') {
        message = body.message;
      }
    } catch {
      // fall through to the generic message
    }
    throw new Error(message);
  }

  const raw = (await res.json()) as Partial<UserServiceGoogleRawResponse>;
  const accessToken = raw.tokens?.accessToken;
  const user = raw.user;
  if (!accessToken || !user) {
    throw new Error('user-service returned an unexpected Google sign-in payload');
  }
  return { accessToken, user };
}

interface AuthorizedUser extends NextAuthUser {
  backendToken: string;
  backendUser: BackendUser;
}

export const { handlers, auth, signIn, signOut } = NextAuth({
  trustHost: true,
  providers: [
    Credentials({
      id: 'google',
      name: 'Google',
      credentials: {
        idToken: { label: 'idToken', type: 'text' },
      },
      async authorize(credentials) {
        const idToken = credentials.idToken;
        if (typeof idToken !== 'string' || idToken.length === 0) {
          return null;
        }
        try {
          const { accessToken, user } = await exchangeGoogleIdToken(idToken);
          const authorized: AuthorizedUser = {
            id: user.id,
            name: user.name,
            email: user.email,
            image: user.avatar_url,
            backendToken: accessToken,
            backendUser: user,
          };
          return authorized;
        } catch (err) {
          // Auth.js v5 surfaces a generic `CredentialsSignin` error to the
          // client regardless of what we throw here, so log details
          // server-side and return null. The login form shows a generic
          // "sign-in failed" message; deeper diagnostics live in server logs.
          console.error('Google sign-in via user-service failed:', err);
          return null;
        }
      },
    }),
  ],
  pages: {
    signIn: '/login',
    error: '/login',
  },
  session: {
    strategy: 'jwt',
  },
  callbacks: {
    jwt({ token, user }) {
      // Auth.js v5 types `user` as non-nullable, but at runtime it's only
      // passed on initial sign-in (undefined on subsequent JWT refreshes).
      // Cast through `| undefined` so the check reflects real behavior.
      const authorized = user as AuthorizedUser | undefined;
      if (authorized) {
        token.backendToken = authorized.backendToken;
        token.backendUser = authorized.backendUser;
      }
      return token;
    },
    session({ session, token }) {
      if (typeof token.backendToken === 'string') {
        session.backendToken = token.backendToken;
      }
      if (token.backendUser) {
        session.backendUser = token.backendUser;
      }
      return session;
    },
  },
});
