# =============================================================================
# Dev environment — combined schema for {{PROJECT}}-core + user-service.
#
# Copy this file twice:
#   cp env.example env/{{PROJECT}}-core.env
#   cp env.example env/user-service.env
#
# Defaults below work zero-setup against the bundled dev stack at
# http://localhost:{{DEV_NGINX_PORT}}. Fill in third-party API keys only for the features
# you're actually testing.
#
# LOCAL ONLY — never commit, never use against staging or prod.
# =============================================================================

NODE_ENV=development
PORT=3000

# -----------------------------------------------------------------------------
# Database — bundled container, resolved via docker network DNS
# -----------------------------------------------------------------------------
{{#MONGO}}# ?replicaSet=rs0&directConnection=true is required so the MongoDB driver
# starts multi-document transactions against the single-node replica set
# defined in dev/docker-compose.yml. Removing these params will surface as
# "Transaction numbers are only allowed on a replica set member or mongos".
MONGODB_URI=mongodb://mongo:27017/{{PROJECT}}?replicaSet=rs0&directConnection=true
{{/MONGO}}{{#POSTGRES}}DATABASE_URL=postgresql://dev:dev@postgres:5432/{{PROJECT}}
{{/POSTGRES}}{{#MYSQL}}DATABASE_URL=mysql://dev:dev@mysql:3306/{{PROJECT}}
{{/MYSQL}}
{{#REDIS}}# -----------------------------------------------------------------------------
# Redis — bundled container
# -----------------------------------------------------------------------------
REDIS_URL=redis://redis:6379

{{/REDIS}}# -----------------------------------------------------------------------------
# JWT — shared between {{PROJECT}}-core and user-service for token validation.
# user-service issues with HS256 and signs `iss`/`aud` from JWT_ISSUER /
# JWT_AUDIENCE; {{PROJECT}}-core rejects tokens whose iss/aud don't match.
# -----------------------------------------------------------------------------
JWT_ACCESS_SECRET=dev-jwt-access-secret-not-for-prod
JWT_REFRESH_SECRET=dev-jwt-refresh-secret-not-for-prod
JWT_ACCESS_EXPIRATION=15m
JWT_REFRESH_EXPIRATION=7d
JWT_ISSUER=karigor
JWT_AUDIENCE=karigor-users

# -----------------------------------------------------------------------------
# App URLs
# -----------------------------------------------------------------------------
APP_BASE_URL=http://localhost:{{DEV_NGINX_PORT}}

# -----------------------------------------------------------------------------
# API contract
# -----------------------------------------------------------------------------
API_BASE={{API_BASE}}
API_VERSION_HEADER={{API_VERSION_HEADER}}
API_VERSION_DEFAULT={{API_VERSION_DEFAULT}}

# -----------------------------------------------------------------------------
# user-service: Google OAuth — leave as placeholder until you wire it up
# Create credentials at https://console.cloud.google.com/apis/credentials
# -----------------------------------------------------------------------------
GOOGLE_CLIENT_ID=your-google-client-id
GOOGLE_CLIENT_SECRET=your-google-client-secret
GOOGLE_CALLBACK_URL=http://localhost:{{DEV_NGINX_PORT}}{{API_BASE}}/auth/google/callback

# -----------------------------------------------------------------------------
# user-service: image upload tuning
# -----------------------------------------------------------------------------
IMAGE_MAX_DIMENSION=400
IMAGE_COMPRESSION_QUALITY=80
IMAGE_MAX_FILE_SIZE=10485760

# -----------------------------------------------------------------------------
# user-service: email — disabled in dev. Leaving EMAIL_PROVIDER unset means
# user-service never tries to wire up a transport at startup, so the resend /
# mailgun blocks below stay out of the file until you actually need them.
# If you turn EMAIL_VERIFICATION_ENABLED=true, also set EMAIL_PROVIDER and
# the matching provider credentials.
# -----------------------------------------------------------------------------
EMAIL_VERIFICATION_ENABLED=false
FRONTEND_URL=http://localhost:3000

# -----------------------------------------------------------------------------
# Logging
# -----------------------------------------------------------------------------
LOG_LEVEL=debug
