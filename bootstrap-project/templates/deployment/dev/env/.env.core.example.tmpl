# =============================================================================
# Remote dev environment — {{PROJECT}}-core service config.
#
# Copy and fill in:
#   cp .env.core.example {{PROJECT}}-core.env
#
# Upload to the remote dev VM via scp / gcloud scp (see dev/REBUILD.md).
# Never commit the populated .env file.
# =============================================================================

NODE_ENV=production
PORT=3000

# -----------------------------------------------------------------------------
# Database — remote dev DB (separate DB name on the same hosted cluster, or
# a dedicated cluster if you're paying for it)
# -----------------------------------------------------------------------------
{{#MONGO}}MONGODB_URI=<FILL_IN_DEV_MONGO_URI>
{{/MONGO}}{{#POSTGRES}}DATABASE_URL=<FILL_IN_DEV_POSTGRES_URL>
{{/POSTGRES}}{{#MYSQL}}DATABASE_URL=<FILL_IN_DEV_MYSQL_URL>
{{/MYSQL}}
{{#REDIS}}# -----------------------------------------------------------------------------
# Redis — managed Redis or a self-hosted instance on the same VM
# -----------------------------------------------------------------------------
REDIS_URL=<FILL_IN_DEV_REDIS_URL>

{{/REDIS}}# -----------------------------------------------------------------------------
# JWT — must match the values in user-service.env (token validation only).
# JWT_ISSUER / JWT_AUDIENCE are verified by {{PROJECT}}-core on every request.
# -----------------------------------------------------------------------------
JWT_ACCESS_SECRET=<FILL_IN_DEV_JWT_ACCESS_SECRET>
JWT_ISSUER=karigor
JWT_AUDIENCE=karigor-users

# -----------------------------------------------------------------------------
# API contract — reject requests whose API version header doesn't match a
# supported version. Defaults to false (lenient).
# -----------------------------------------------------------------------------
API_VERSION_STRICT=false

# -----------------------------------------------------------------------------
# Logging
# -----------------------------------------------------------------------------
LOG_LEVEL=info
