# =============================================================================
# Staging environment — user-service config.
#
# Copy and fill in:
#   cp .env.user-service.example user-service.env
# =============================================================================

NODE_ENV=production
PORT=3000

# -----------------------------------------------------------------------------
# Database (user-service owns its own DB or shares with core)
# -----------------------------------------------------------------------------
{{#MONGO}}MONGODB_URI=<FILL_IN_STAGING_MONGO_URI>
{{/MONGO}}{{#POSTGRES}}DATABASE_URL=<FILL_IN_STAGING_POSTGRES_URL>
{{/POSTGRES}}{{#MYSQL}}DATABASE_URL=<FILL_IN_STAGING_MYSQL_URL>
{{/MYSQL}}
# -----------------------------------------------------------------------------
# JWT — must match the values in {{PROJECT}}-core.env.
# user-service signs `iss`/`aud` from JWT_ISSUER / JWT_AUDIENCE and
# {{PROJECT}}-core verifies them on every request.
# -----------------------------------------------------------------------------
JWT_ACCESS_SECRET=<FILL_IN_STAGING_JWT_ACCESS_SECRET>
JWT_REFRESH_SECRET=<FILL_IN_STAGING_JWT_REFRESH_SECRET>
JWT_ACCESS_EXPIRATION=15m
JWT_REFRESH_EXPIRATION=7d
JWT_ISSUER=karigor
JWT_AUDIENCE=karigor-users

# -----------------------------------------------------------------------------
# App URLs
# -----------------------------------------------------------------------------
APP_BASE_URL=https://{{STAGING_DOMAIN}}
FRONTEND_URL=https://{{STAGING_DOMAIN}}

# -----------------------------------------------------------------------------
# Google OAuth
# -----------------------------------------------------------------------------
GOOGLE_CLIENT_ID=<FILL_IN_GOOGLE_CLIENT_ID>
GOOGLE_CLIENT_SECRET=<FILL_IN_GOOGLE_CLIENT_SECRET>
GOOGLE_CALLBACK_URL=https://{{STAGING_DOMAIN}}{{API_BASE}}/auth/google/callback

# -----------------------------------------------------------------------------
# Email (Resend or SMTP)
# -----------------------------------------------------------------------------
EMAIL_VERIFICATION_ENABLED=true
EMAIL_PROVIDER=resend
RESEND_API_KEY=<FILL_IN_RESEND_API_KEY>
RESEND_FROM_EMAIL=<FILL_IN_FROM_EMAIL>

# -----------------------------------------------------------------------------
# Asset/image upload
# -----------------------------------------------------------------------------
IMAGE_MAX_DIMENSION=400
IMAGE_COMPRESSION_QUALITY=80
IMAGE_MAX_FILE_SIZE=10485760
ASSET_BUCKET=<FILL_IN_S3_OR_GCS_BUCKET>

LOG_LEVEL=info
