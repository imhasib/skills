# =============================================================================
# Staging environment — {{PROJECT}}-core service config.
#
# Copy and fill in:
#   cp .env.core.example {{PROJECT}}-core.env
#
# Upload to the staging VM via scp / gcloud scp (see staging/REBUILD.md).
# Never commit the populated .env file.
# =============================================================================

NODE_ENV=production
PORT=3000

# -----------------------------------------------------------------------------
# Database — staging DB (separate DB name on the same hosted cluster, or
# a dedicated staging cluster if you're paying for it)
# -----------------------------------------------------------------------------
{{#MONGO}}MONGODB_URI=<FILL_IN_STAGING_MONGO_URI>
{{/MONGO}}{{#POSTGRES}}DATABASE_URL=<FILL_IN_STAGING_POSTGRES_URL>
{{/POSTGRES}}{{#MYSQL}}DATABASE_URL=<FILL_IN_STAGING_MYSQL_URL>
{{/MYSQL}}
{{#REDIS}}# -----------------------------------------------------------------------------
# Redis — managed Redis or a self-hosted instance on the same VM
# -----------------------------------------------------------------------------
REDIS_URL=<FILL_IN_STAGING_REDIS_URL>

{{/REDIS}}# -----------------------------------------------------------------------------
# JWT — must match the values in user-service.env (token validation only).
# JWT_ISSUER / JWT_AUDIENCE are verified by {{PROJECT}}-core on every request.
# -----------------------------------------------------------------------------
JWT_ACCESS_SECRET=<FILL_IN_STAGING_JWT_ACCESS_SECRET>
JWT_REFRESH_SECRET=<FILL_IN_STAGING_JWT_REFRESH_SECRET>
JWT_ACCESS_EXPIRATION=15m
JWT_REFRESH_EXPIRATION=7d
JWT_ISSUER=karigor
JWT_AUDIENCE=karigor-users

# -----------------------------------------------------------------------------
# App URLs
# -----------------------------------------------------------------------------
APP_BASE_URL=https://{{STAGING_DOMAIN}}

# -----------------------------------------------------------------------------
# API contract
# -----------------------------------------------------------------------------
API_BASE={{API_BASE}}
API_VERSION_HEADER={{API_VERSION_HEADER}}
API_VERSION_DEFAULT={{API_VERSION_DEFAULT}}

# -----------------------------------------------------------------------------
# Logging
# -----------------------------------------------------------------------------
LOG_LEVEL=info
