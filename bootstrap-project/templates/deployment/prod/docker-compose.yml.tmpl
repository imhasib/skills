# Production compose — stamped at bootstrap with placeholders.
# Production setup is DEFERRED at bootstrap. Run `/configure-prod` from the
# workspace root to fill in <FILL_IN_*> values when ready to publish.
#
# Same shape as the remote dev stack, but with full resource budgets and direct port bind
# (or behind host-level Caddy — see prod/REBUILD.md once /configure-prod runs).

services:
  user-service:
    image: {{IMAGE_PREFIX}}/user-service:${USER_SERVICE_TAG:-latest}
    pull_policy: always
    container_name: {{PROJECT}}-user-service
    restart: unless-stopped
    env_file:
      - ./env/user-service.env
    healthcheck:
      # user-service exposes GET /health (200 = ready). Gates {{PROJECT}}-core
      # boot via condition: service_healthy so core never tries to validate JWTs
      # against an upstream that's still starting.
      test: ["CMD-SHELL", "wget --no-verbose --tries=1 --spider http://localhost:3000/health || exit 1"]
      interval: 10s
      timeout: 5s
      retries: 5
      start_period: 15s
    networks:
      - {{PROJECT}}-network
    deploy:
      resources:
        limits:
          memory: 512M
          cpus: '0.5'
        reservations:
          memory: 256M
          cpus: '0.25'
    logging:
      driver: json-file
      options:
        max-size: "10m"
        max-file: "3"

  {{PROJECT}}-core:
    image: {{IMAGE_PREFIX}}/{{PROJECT}}-core:${CORE_TAG:-latest}
    pull_policy: always
    container_name: {{PROJECT}}-core
    restart: unless-stopped
    env_file:
      - ./env/{{PROJECT}}-core.env
    depends_on:
      user-service:
        condition: service_healthy
    networks:
      - {{PROJECT}}-network
    deploy:
      resources:
        limits:
          memory: 512M
          cpus: '0.5'
        reservations:
          memory: 256M
          cpus: '0.25'
    logging:
      driver: json-file
      options:
        max-size: "10m"
        max-file: "3"

{{#WEB_ADMIN}}  {{PROJECT}}-web-admin:
    image: {{IMAGE_PREFIX}}/{{PROJECT}}-web-admin:${WEB_ADMIN_TAG:-latest}
    pull_policy: always
    container_name: {{PROJECT}}-web-admin
    restart: unless-stopped
    ports:
      - "${WEB_ADMIN_PORT:-3031}:3000"
    networks:
      - {{PROJECT}}-network
    deploy:
      resources:
        limits:
          memory: 512M
          cpus: '0.5'
        reservations:
          memory: 256M
          cpus: '0.25'
    logging:
      driver: json-file
      options:
        max-size: "10m"
        max-file: "3"

{{/WEB_ADMIN}}{{#WEB}}  {{PROJECT}}-web:
    image: {{IMAGE_PREFIX}}/{{PROJECT}}-web:${WEB_TAG:-latest}
    pull_policy: always
    container_name: {{PROJECT}}-web
    restart: unless-stopped
    ports:
      - "${WEB_APP_PORT:-3032}:3000"
    networks:
      - {{PROJECT}}-network
    deploy:
      resources:
        limits:
          memory: 512M
          cpus: '0.5'
        reservations:
          memory: 256M
          cpus: '0.25'
    logging:
      driver: json-file
      options:
        max-size: "10m"
        max-file: "3"

{{/WEB}}  swagger-ui:
    image: swaggerapi/swagger-ui
    container_name: {{PROJECT}}-swagger-ui
    restart: unless-stopped
    environment:
      URLS: "${SWAGGER_URLS:-[{url: '/api-docs/specs/user-service.json', name: 'User Service'}, {url: '/api-docs/specs/{{PROJECT}}-core.json', name: '{{PROJECT}} Core'}]}"
      BASE_URL: "${SWAGGER_BASE_URL:-/api-docs}"
    networks:
      - {{PROJECT}}-network
    deploy:
      resources:
        limits:
          memory: 128M
          cpus: '0.25'
        reservations:
          memory: 64M
          cpus: '0.1'

  nginx:
    image: nginx:alpine
    container_name: {{PROJECT}}-nginx-proxy
    restart: unless-stopped
    ports:
      - "${NGINX_PORT:-3030}:80"
    volumes:
      - ./nginx/nginx.conf:/etc/nginx/nginx.conf:ro
      - ../shared/nginx/locations.conf:/etc/nginx/locations.conf:ro
      - ../shared/nginx/proxy-params.conf:/etc/nginx/proxy-params.conf:ro
      - ../shared/nginx/proxy-params-minimal.conf:/etc/nginx/proxy-params-minimal.conf:ro
      - ../shared/nginx/cors.conf:/etc/nginx/cors.conf:ro
    depends_on:
      - user-service
      - {{PROJECT}}-core
      - swagger-ui
    networks:
      - {{PROJECT}}-network
    deploy:
      resources:
        limits:
          memory: 128M
          cpus: '0.25'
        reservations:
          memory: 64M
          cpus: '0.1'
    logging:
      driver: json-file
      options:
        max-size: "5m"
        max-file: "3"

networks:
  {{PROJECT}}-network:
    # External — created out-of-band: `sudo docker network create {{PROJECT}}-network`
    # Shared with the logging stack so Promtail can scrape app containers.
    external: true
    name: {{PROJECT}}-network
