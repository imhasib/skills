# =============================================================================
# Production environment — user-service config.
# Stamped at bootstrap with placeholders. Filled in by /configure-prod.
# =============================================================================

NODE_ENV=production
PORT=3000

{{#MONGO}}MONGODB_URI=<FILL_IN_PROD_MONGO_URI>
{{/MONGO}}{{#POSTGRES}}DATABASE_URL=<FILL_IN_PROD_POSTGRES_URL>
{{/POSTGRES}}{{#MYSQL}}DATABASE_URL=<FILL_IN_PROD_MYSQL_URL>
{{/MYSQL}}
# JWT — must match {{PROJECT}}-core.env. user-service issues with iss/aud
# from JWT_ISSUER / JWT_AUDIENCE; {{PROJECT}}-core rejects on mismatch.
JWT_ACCESS_SECRET=<FILL_IN_PROD_JWT_ACCESS_SECRET>
JWT_REFRESH_SECRET=<FILL_IN_PROD_JWT_REFRESH_SECRET>
JWT_ACCESS_EXPIRATION=15m
JWT_REFRESH_EXPIRATION=7d
JWT_ISSUER=karigor
JWT_AUDIENCE=karigor-users

APP_BASE_URL=https://<FILL_IN_PROD_DOMAIN>
FRONTEND_URL=https://<FILL_IN_PROD_DOMAIN>

GOOGLE_CLIENT_ID=<FILL_IN_GOOGLE_CLIENT_ID>
GOOGLE_CLIENT_SECRET=<FILL_IN_GOOGLE_CLIENT_SECRET>
GOOGLE_CALLBACK_URL=https://<FILL_IN_PROD_DOMAIN>{{API_BASE}}/auth/google/callback

EMAIL_VERIFICATION_ENABLED=true
EMAIL_PROVIDER=resend
RESEND_API_KEY=<FILL_IN_RESEND_API_KEY>
RESEND_FROM_EMAIL=<FILL_IN_FROM_EMAIL>

IMAGE_MAX_DIMENSION=400
IMAGE_COMPRESSION_QUALITY=80
IMAGE_MAX_FILE_SIZE=10485760
ASSET_BUCKET=<FILL_IN_S3_OR_GCS_BUCKET>

LOG_LEVEL=info
