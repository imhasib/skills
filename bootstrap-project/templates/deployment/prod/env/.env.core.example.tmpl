# =============================================================================
# Production environment — {{PROJECT}}-core service config.
# Stamped at bootstrap with placeholders. Filled in by /configure-prod.
#
# Copy and fill in:
#   cp .env.core.example {{PROJECT}}-core.env
# Upload to the prod VM via scp (see prod/REBUILD.md once /configure-prod runs).
# =============================================================================

NODE_ENV=production
PORT=3000

# -----------------------------------------------------------------------------
# Database — production DB (dedicated cluster recommended)
# -----------------------------------------------------------------------------
{{#MONGO}}MONGODB_URI=<FILL_IN_PROD_MONGO_URI>
{{/MONGO}}{{#POSTGRES}}DATABASE_URL=<FILL_IN_PROD_POSTGRES_URL>
{{/POSTGRES}}{{#MYSQL}}DATABASE_URL=<FILL_IN_PROD_MYSQL_URL>
{{/MYSQL}}
{{#REDIS}}REDIS_URL=<FILL_IN_PROD_REDIS_URL>

{{/REDIS}}# JWT — must match user-service.env. JWT_ISSUER / JWT_AUDIENCE are
# verified by {{PROJECT}}-core on every request and rejected if they don't match.
JWT_ACCESS_SECRET=<FILL_IN_PROD_JWT_ACCESS_SECRET>
JWT_ISSUER=karigor
JWT_AUDIENCE=karigor-users

# Reject requests whose API version header doesn't match a supported version.
# Defaults to false (lenient). Set to true to enforce strictly in prod.
API_VERSION_STRICT=false

LOG_LEVEL=info
