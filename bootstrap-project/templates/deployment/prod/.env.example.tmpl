# Production host-side config — ports, grafana admin password.
# Stamped at bootstrap with placeholders. Filled in by /configure-prod.
#
# Copy this to prod/.env before the first prod deploy:
#   cp .env.example .env
# Then edit to set real values. Never commit the populated .env.

# Nginx host port (the host-level Caddy reverse-proxies the public domain here).
NGINX_PORT=3030

# Service host ports
USER_SERVICE_PORT=3031
CORE_PORT=3035

{{#WEB_ADMIN}}# Admin portal — host port mapped to {{PROJECT}}-web-admin:3000.
WEB_ADMIN_PORT=3031
{{/WEB_ADMIN}}{{#WEB}}# Public web — host port mapped to {{PROJECT}}-web:3000.
WEB_PORT=3032
{{/WEB}}
# -----------------------------------------------------------------------------
# Image tags — passed inline at deploy time, NOT stored persistently here.
# `sudo -E docker compose ...` is load-bearing: without -E the exported tags
# are lost in the sudo subshell and compose falls back to `:latest`.
# Tag format is sha-<short-git-sha> for SHA-pinned deploys.
#   export USER_SERVICE_TAG=sha-abc1234
#   export CORE_TAG=sha-def5678
# -----------------------------------------------------------------------------

# -----------------------------------------------------------------------------
# Grafana admin password — used by docker-compose.logging.yml.
# CHANGE this before the first deploy. Grafana only honours the value on the
# very first startup; later restarts keep the existing password.
# Rotate later with:
#   docker exec -it {{PROJECT}}-grafana grafana-cli admin reset-admin-password '<new>'
# -----------------------------------------------------------------------------
GRAFANA_ADMIN_PASSWORD=<FILL_IN_BEFORE_FIRST_DEPLOY>

# Host port that Caddy reverse-proxies the Grafana public hostname to.
# Bound to 127.0.0.1 only — not directly reachable from the public internet.
GRAFANA_HOST_PORT=3050
