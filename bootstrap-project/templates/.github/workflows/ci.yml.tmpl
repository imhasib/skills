name: ci

on:
  pull_request:
    branches: [dev, main]
  push:
    branches: [dev]

jobs:
  lint-and-typecheck:
    runs-on: ubuntu-latest
    steps:
      - uses: actions/checkout@v4
      - uses: actions/setup-node@v4
        with:
          node-version: "{{NODE_VERSION}}"
          cache: "{{PACKAGE_MANAGER}}"
      - run: {{PACKAGE_MANAGER}} ci
      - run: {{PACKAGE_MANAGER}} run lint
      - run: {{PACKAGE_MANAGER}} run typecheck

  unit:
    runs-on: ubuntu-latest
    needs: lint-and-typecheck
    steps:
      - uses: actions/checkout@v4
      - uses: actions/setup-node@v4
        with:
          node-version: "{{NODE_VERSION}}"
          cache: "{{PACKAGE_MANAGER}}"
      - run: {{PACKAGE_MANAGER}} ci
      - run: {{PACKAGE_MANAGER}} test

  integration:
    runs-on: ubuntu-latest
    needs: lint-and-typecheck
    services:
{{#MONGO}}      mongo:
        image: mongo:7
        ports: ["27017:27017"]
        options: >-
          --health-cmd "mongosh --eval 'db.adminCommand({ ping: 1 })'"
          --health-interval 10s
          --health-timeout 5s
          --health-retries 5
{{/MONGO}}{{#POSTGRES}}      postgres:
        image: postgres:16-alpine
        env:
          POSTGRES_USER: ci
          POSTGRES_PASSWORD: ci
          POSTGRES_DB: ci_test
        ports: ["5432:5432"]
        options: >-
          --health-cmd pg_isready
          --health-interval 10s
          --health-timeout 5s
          --health-retries 5
{{/POSTGRES}}{{#REDIS}}      redis:
        image: redis:7-alpine
        ports: ["6379:6379"]
        options: >-
          --health-cmd "redis-cli ping"
          --health-interval 10s
          --health-timeout 5s
          --health-retries 5
{{/REDIS}}    steps:
      - uses: actions/checkout@v4
      - uses: actions/setup-node@v4
        with:
          node-version: "{{NODE_VERSION}}"
          cache: "{{PACKAGE_MANAGER}}"
      - run: {{PACKAGE_MANAGER}} ci
      - run: {{PACKAGE_MANAGER}} run test:int
        env:
{{#MONGO}}          MONGODB_URI: mongodb://localhost:27017/ci_test
{{/MONGO}}{{#POSTGRES}}          DATABASE_URL: postgresql://ci:ci@localhost:5432/ci_test
{{/POSTGRES}}{{#REDIS}}          REDIS_URL: redis://localhost:6379
{{/REDIS}}          NODE_ENV: test
