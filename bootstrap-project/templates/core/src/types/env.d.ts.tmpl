// Augments process.env with typed names. Authoritative validation lives in config.ts.
declare namespace NodeJS {
  interface ProcessEnv {
    NODE_ENV: 'development' | 'test' | 'production';
    PORT?: string;
    LOG_LEVEL?: string;
    API_VERSION_STRICT?: string;

{{#MONGO}}    MONGODB_URI: string;
{{/MONGO}}{{#POSTGRES}}    DATABASE_URL: string;
{{/POSTGRES}}{{#MYSQL}}    DATABASE_URL: string;
{{/MYSQL}}{{#REDIS}}    REDIS_URL: string;
{{/REDIS}}
    JWT_ACCESS_SECRET: string;
    JWT_ISSUER?: string;
    JWT_AUDIENCE?: string;
  }
}

export {};
