# =============================================================================
# {{PROJECT}}-core — local dev env.
#
#   cp .env.example .env
#
# These values target NATIVE `npm run dev` against host-mapped ports
# (mongo, redis, etc. bound to localhost by docker-compose.dev.yml).
# When running the app *inside* docker-compose, the compose file overrides
# the URIs below with container hostnames — so `localhost` here is fine.
# =============================================================================

NODE_ENV=development
PORT=3000
LOG_LEVEL=debug

# API contract
API_VERSION_STRICT=false

# Database — host-mapped port; compose overrides to container hostname when dockerized
{{#MONGO}}MONGODB_URI=mongodb://localhost:27017/{{PROJECT}}
{{/MONGO}}{{#POSTGRES}}DATABASE_URL=postgresql://dev:dev@localhost:5432/{{PROJECT}}
{{/POSTGRES}}{{#MYSQL}}DATABASE_URL=mysql://dev:dev@localhost:3306/{{PROJECT}}
{{/MYSQL}}
{{#REDIS}}# Cache
REDIS_URL=redis://localhost:6379

{{/REDIS}}# JWT — must match user-service's signing config. user-service uses these
# exact env names. JWT_ISSUER / JWT_AUDIENCE default to user-service defaults
# (karigor / karigor-users); only set if user-service overrides them.
JWT_ACCESS_SECRET=dev-jwt-access-secret-not-for-prod
JWT_ISSUER=karigor
JWT_AUDIENCE=karigor-users
